<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_partner_form_inherit_asesmen" model="ir.ui.view">
    <field name="name">res.partner.form.custom_billing_asesmen</field>
    <field name="model">res.partner</field>
    <field name="inherit_id" ref="base.view_partner_form"/>
    <field name="arch" type="xml">
      <xpath expr="//sheet" position="inside">
        <group string="Asesi" name="custom_billing_asesmen_group">
          <field name="tipe_asesi" widget="radio"/>
        </group>
      </xpath>
    </field>
  </record>
</odoo>
