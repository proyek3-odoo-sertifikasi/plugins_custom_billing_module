<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="product_template_form_inherit_asesmen" model="ir.ui.view">
    <field name="name">product.template.form.custom_billing_asesmen</field>
    <field name="model">product.template</field>
    <field name="inherit_id" ref="product.product_template_only_form_view"/>
    <field name="arch" type="xml">
      <xpath expr="//field[@name='list_price']" position="after">
        <group string="Tarif Asesmen">
          <field name="tarif_internal"/>
          <field name="tarif_eksternal"/>
        </group>
      </xpath>
    </field>
  </record>
</odoo>
